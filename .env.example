# ==================== 应用配置 ====================

# 应用端口
APP_PORT=8501

# Flask 环境
FLASK_ENV=production

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 日志格式 (json, text)
LOG_FORMAT=json

# ==================== Docker 日志配置 ====================

# 日志驱动 (json-file, syslog, none)
LOG_DRIVER=json-file

# 单个日志文件最大大小
LOG_MAX_SIZE=10m

# 保留的日志文件数量
LOG_MAX_FILES=7

# 日志标签 (逗号分隔)
LOG_LABELS=app,service

# 日志环境变量 (逗号分隔)
LOG_ENV=FLASK_ENV,LOG_LEVEL

# ==================== 资源限制 ====================

# 内存限制
MEM_LIMIT=2g

# CPU 核心数
CPUS=1.0

# ==================== 目录配置 ====================

# 数据目录 (建议使用绝对路径)
DATA_DIR=./data

# 日志目录
LOG_DIR=./logs

# 备份目录
BACKUP_DIR=./backups

# ==================== 备份配置 ====================

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# 自动备份时间 (cron 格式)
BACKUP_SCHEDULE=0 2 * * *

# ==================== 数据库配置 ====================

# 数据库路径
DB_PATH=/app/data/vision_platform.db
